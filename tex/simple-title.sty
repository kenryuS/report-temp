\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{simpleTitle}

\usepackage{tex/coms}

\newcommand{\simpletitle}{
    \begin{titlepage}
        \thispagestyle{empty}
        \begin{center}
            \Huge
            {\@title}

            \vspace{0.5cm}
            \large
            {\@author}

            \vfill

            {提出日：\@turninyear \@turninmonth \@turninday}

            {\@year \@month \@day}

            \vspace{0.25cm}
        \end{center}
    \end{titlepage}
}
